    <title>自定义View小结</title>
    <link>http://mrljdx.com/%E8%87%AA%E5%AE%9A%E4%B9%89view%E5%B0%8F%E7%BB%93/</link>
    <pubDate>Tue, 14 Apr 2015 09:13:53 &#43;0000</pubDate>
